# Spiced local configuration example.
# Copy this file to ".env" and fill in your own values.
# NEVER commit your real .env file or paste real keys into code, logs, or screenshots.

# Google Gemini API key. Get one at https://aistudio.google.com/app/apikey
# The app reads this from the environment (or a local .env) at runtime.
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override the default Gemini model.
# GEMINI_MODEL=gemini-1.5-flash

# Optional: choose the active AI provider ("mock" or "gemini"). Defaults to "mock".
# SPICED_AI_PROVIDER=mock
