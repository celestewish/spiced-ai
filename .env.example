# Spiced local configuration example.
# Copy this file to ".env" and fill in your own values.
# NEVER commit your real .env file or paste real keys into code, logs, or screenshots.

# --- OpenAI (default provider) ---
# OpenAI API key. Get one at https://platform.openai.com/api-keys
# The app reads this from the environment (or a local .env) at runtime.
OPENAI_API_KEY=your-openai-api-key-here

# Optional: override the OpenAI model. Defaults to a conservative, widely
# available model. If you see a "model not found" error, set this to a model
# your API key has access to.
# OPENAI_MODEL=gpt-4o-mini

# --- Provider selection ---
# Optional: choose the active AI provider ("openai", "mock", or "gemini").
# Defaults to "openai". Use "mock" for free, offline testing.
# SPICED_AI_PROVIDER=openai

# --- Gemini (optional, not the default) ---
# Only needed if you switch the provider to "gemini". Requires the optional
# "gemini" extra: pip install -e ".[gemini]"
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash
